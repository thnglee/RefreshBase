{{ 'video-carousel.css' | asset_url | stylesheet_tag }}

<section class="video-carousel" id="video-carousel">
  <div class="video-carousel__inner">
    {%- comment -%} ── Trustpilot badge ─────────────────────────── {%- endcomment -%}
    <div class="video-carousel__trust">
      {%- if section.settings.trust_image != blank -%}
        <img
          src="{{ section.settings.trust_image | image_url: width: 400 }}"
          alt="{{ section.settings.trust_image.alt | default: 'Trustpilot' }}"
          width="200"
          height="{{ 200 | divided_by: section.settings.trust_image.aspect_ratio | round }}"
          loading="lazy"
          class="video-carousel__trust-img"
        >
      {%- else -%}
        <div class="video-carousel__trust-placeholder">
          <span class="video-carousel__tp-logo">★ Trustpilot</span>
          <div class="video-carousel__tp-stars">
            <span class="video-carousel__tp-star">★</span>
            <span class="video-carousel__tp-star">★</span>
            <span class="video-carousel__tp-star">★</span>
            <span class="video-carousel__tp-star">★</span>
            <span class="video-carousel__tp-star">★</span>
          </div>
        </div>
      {%- endif -%}
      {%- if section.settings.trust_text != blank -%}
        <p class="video-carousel__trust-text">{{ section.settings.trust_text }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Heading ─────────────────────────────────── {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="video-carousel__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- comment -%} ── Carousel track ──────────────────────────── {%- endcomment -%}
    <div class="video-carousel__track-wrapper">
      <div class="video-carousel__track" id="videoCarouselTrack">
        {%- for block in section.blocks -%}
          {%- if block.type == 'video_slide' -%}
            <div class="video-carousel__slide" {{ block.shopify_attributes }}>
              <div class="video-carousel__thumb">
                {%- if block.settings.thumbnail != blank -%}
                  <img
                    src="{{ block.settings.thumbnail | image_url: width: 600 }}"
                    alt="{{ block.settings.thumbnail.alt | default: 'Video thumbnail' }}"
                    width="300"
                    height="400"
                    loading="lazy"
                    class="video-carousel__thumb-img"
                  >
                {%- else -%}
                  <div class="video-carousel__thumb-placeholder">
                    <span>Thumbnail — select in theme editor</span>
                  </div>
                {%- endif -%}

                {%- comment -%} Play button overlay {%- endcomment -%}
                <button
                  class="video-carousel__play-btn"
                  aria-label="Play video"
                  {%- if block.settings.video_url != blank %}
                    data-video-url="{{ block.settings.video_url }}"
                  {% endif -%}
                >
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="22" fill="rgba(0,0,0,0.45)"/>
                    <path d="M19 14l14 10-14 10V14z" fill="#fff"/>
                  </svg>
                </button>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ── Progress bar + arrows ────────────────────── {%- endcomment -%}
    <div class="video-carousel__controls">
      <div class="video-carousel__progress">
        <div class="video-carousel__progress-bar" id="videoCarouselProgress"></div>
      </div>
      <div class="video-carousel__arrows">
        <button class="video-carousel__arrow video-carousel__arrow--prev" id="videoCarouselPrev" aria-label="Previous">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button class="video-carousel__arrow video-carousel__arrow--next" id="videoCarouselNext" aria-label="Next">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 6 15 12 9 18"/>
          </svg>
        </button>
      </div>
    </div>

    {%- comment -%} ── CTA + Guarantee ─────────────────────────── {%- endcomment -%}
    {%- if section.settings.cta_text != blank -%}
      <div class="video-carousel__cta-wrap">
        <a href="{{ section.settings.cta_link | default: '#' }}" class="video-carousel__cta">
          {{ section.settings.cta_text }}
        </a>
        {%- if section.settings.guarantee_text != blank -%}
          <div class="video-carousel__guarantee">
            {%- if section.settings.guarantee_icon != blank -%}
              <img
                src="{{ section.settings.guarantee_icon | image_url: width: 60 }}"
                alt="Guarantee"
                width="24"
                height="24"
                loading="lazy"
              >
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            {%- endif -%}
            <span>{{ section.settings.guarantee_text }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script src="{{ 'video-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Video Carousel",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Trust Badge"
    },
    {
      "type": "image_picker",
      "id": "trust_image",
      "label": "Trust badge image (e.g. Trustpilot)"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust text",
      "default": "93.000+ Customers Worldwide"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "See The Stories of Sculptique™ Women Firsthand"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Try Lymphatic Drainage Risk-Free"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "60-Day Money-Back Guarantee"
    },
    {
      "type": "image_picker",
      "id": "guarantee_icon",
      "label": "Guarantee icon (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Video thumbnail"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Carousel",
      "blocks": [
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
