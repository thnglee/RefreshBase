    },
    {
      "type": "text",
      "id": "card2_caption",
      "label": "Card 2 caption",
      "default": "You tried viral lymphatic drops from TikTok."
    },
    {
      "type": "text",
      "id": "card2_fail_label",
      "label": "Card 2 fail label",
      "default": "Why it failed"
    },
    {
      "type": "textarea",
      "id": "card2_fail_text",
