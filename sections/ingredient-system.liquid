{{ 'ingredient-system.css' | asset_url | stylesheet_tag }}

<section class="ingredient-system" id="ingredient-system">
  <div class="ingredient-system__inner page-width">
    {%- comment -%} ======== HEADING ======== {%- endcomment -%}
    <div class="ingredient-system__header">
      <h2 class="ingredient-system__title">
        <span class="ingredient-system__title--green">{{ section.settings.heading_green }}</span>
        {{ section.settings.heading_black }}
      </h2>
      <p class="ingredient-system__subtitle">{{ section.settings.subtitle }}</p>
    </div>

    {%- comment -%} ======== INGREDIENT GRID ======== {%- endcomment -%}
    <div class="ingredient-system__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
          <details class="ingredient-card" {{ block.shopify_attributes }}>
            <summary class="ingredient-card__summary">
              <div class="ingredient-card__benefit">
                <svg class="ingredient-card__check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect width="24" height="24" rx="4" fill="#2a9d5c"/>
                  <path d="M6 12l4 4 8-8" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="ingredient-card__benefit-text">{{ block.settings.benefit_title }}</span>
              </div>

              <div class="ingredient-card__ingredient-row">
                {%- if block.settings.image != blank -%}
                  <img
                    class="ingredient-card__img"
                    src="{{ block.settings.image | image_url: width: 120 }}"
                    alt="{{ block.settings.image.alt | default: block.settings.ingredient_name }}"
                    width="60"
                    height="60"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="ingredient-card__img-placeholder"></div>
                {%- endif -%}
                <span class="ingredient-card__name">
                  {{- block.settings.ingredient_name }} ({{ block.settings.dosage }})</span
                >
                <svg class="ingredient-card__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </summary>

            <div class="ingredient-card__body">
              <p>{{ block.settings.description }}</p>
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ======== SYNERGISTIC EFFECT BOX ======== {%- endcomment -%}
    <div class="ingredient-system__synergy">
      <h3 class="ingredient-system__synergy-title">{{ section.settings.synergy_heading }}</h3>
      <p class="ingredient-system__synergy-intro">{{ section.settings.synergy_intro }}</p>

      <ul class="ingredient-system__synergy-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'synergy_item' -%}
            <li {{ block.shopify_attributes }}>
              <svg class="ingredient-system__synergy-check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect width="24" height="24" rx="4" fill="#2a9d5c"/>
                <path d="M6 12l4 4 8-8" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <p class="ingredient-system__synergy-closing">{{ section.settings.synergy_closing }}</p>
    </div>
  </div>
</section>

