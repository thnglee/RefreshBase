{{ 'benefits-expert.css' | asset_url | stylesheet_tag }}

<section class="benefits-expert" id="benefits-expert">
  {%- comment -%} ============ PART 1: Benefit Icons Bar ============ {%- endcomment -%}
  <div class="benefits-bar">
    <div class="benefits-bar__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'benefit_icon' -%}
          <div class="benefits-bar__item" {{ block.shopify_attributes }}>
            <div class="benefits-bar__icon-wrap">
              {%- if block.settings.icon_image != blank -%}
                <img
                  src="{{ block.settings.icon_image | image_url: width: 120 }}"
                  alt="{{ block.settings.icon_image.alt | default: block.settings.title }}"
                  width="60"
                  height="60"
                  loading="lazy"
                  class="benefits-bar__icon-img"
                >
              {%- else -%}
                <div class="benefits-bar__icon-placeholder">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#2a9d5c"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="3"/>
                    <circle cx="12" cy="10" r="3"/>
                    <path d="M6 21v-1a6 6 0 0112 0v1"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <p class="benefits-bar__title">{{ block.settings.title }}</p>
            <p class="benefits-bar__subtitle">{{ block.settings.subtitle }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ============ PART 2: Expert Advice Box ============ {%- endcomment -%}
  <div class="expert-box">
    <div class="expert-box__inner">
      <div class="expert-box__text-col">
        {%- if section.settings.expert_date != blank -%}
          <p class="expert-box__date">{{ section.settings.expert_date }}</p>
        {%- endif -%}

        <h2 class="expert-box__heading">{{ section.settings.expert_heading }}</h2>

        {%- if section.settings.expert_quote_1 != blank -%}
          <p class="expert-box__quote">{{ section.settings.expert_quote_1 }}</p>
        {%- endif -%}

        {%- if section.settings.expert_quote_2 != blank -%}
          <p class="expert-box__quote">{{ section.settings.expert_quote_2 }}</p>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a
            href="{{ section.settings.cta_link | default: '#' }}"
            class="expert-box__cta"
          >
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.guarantee_text != blank -%}
          <div class="expert-box__guarantee">
            {%- if section.settings.guarantee_icon != blank -%}
              <img
                src="{{ section.settings.guarantee_icon | image_url: width: 60 }}"
                alt="Guarantee"
                width="30"
                height="30"
                loading="lazy"
                class="expert-box__guarantee-icon"
              >
            {%- else -%}
              <svg
                class="expert-box__guarantee-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            {%- endif -%}
            <span>{{ section.settings.guarantee_text }}</span>
          </div>
        {%- endif -%}
      </div>

      <div class="expert-box__img-col">
        {%- if section.settings.expert_image != blank -%}
          <img
            src="{{ section.settings.expert_image | image_url: width: 800 }}"
            alt="{{ section.settings.expert_image.alt | default: 'Expert photo' }}"
            width="800"
            height="{{ 800 | divided_by: section.settings.expert_image.aspect_ratio | round }}"
            loading="lazy"
            class="expert-box__photo"
          >
        {%- else -%}
          <div class="expert-box__photo-placeholder">
            <span>Expert image — select in theme editor</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits + Expert",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Expert Advice Box"
    },
    {
      "type": "text",
      "id": "expert_date",
      "label": "Date line",
      "default": "July 4th, 2025"
    },
    {
      "type": "text",
      "id": "expert_heading",
      "label": "Heading",
      "default": "Expert Advice from Dr. Emily Chen of a Premier New York Skin Clinic"
    },
    {
      "type": "textarea",
      "id": "expert_quote_1",
      "label": "Quote paragraph 1",
      "default": "\"Your nutrition plays a powerful role in your appearance. If your body is missing key vitamins and nutrients, it can't process fat and upkeep healthy connective tissue, which is why unprocessed fat flows up and starts pushing up against your skin, forming bumps you know as cellulite."
    },
    {
      "type": "textarea",
      "id": "expert_quote_2",
      "label": "Quote paragraph 2",
      "default": "Lymphatic Drainage by Sculptique™ contains ingredients that are scientifically proven to enhance microcirculation, boost lymphatic drainage, and reduce inflammation, which restores your tissue and breaks down the fat cells in your skin.\""
    },
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Expert photo"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Try Lymphatic Drainage Risk-Free"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "60-Day Money-Back Guarantee"
    },
    {
      "type": "image_picker",
      "id": "guarantee_icon",
      "label": "Guarantee icon (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "benefit_icon",
      "name": "Benefit icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Short description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits + Expert",
      "blocks": [
        {
          "type": "benefit_icon",
          "settings": {
            "title": "Free Shipping from USA",
            "subtitle": "On all orders"
          }
        },
        {
          "type": "benefit_icon",
          "settings": {
            "title": "Naturally Supports Your Body",
            "subtitle": "Promotes healthy immune cell functions"
          }
        },
        {
          "type": "benefit_icon",
          "settings": {
            "title": "100% Natural Ingredients",
            "subtitle": "8 active, natural ingredients"
          }
        },
        {
          "type": "benefit_icon",
          "settings": {
            "title": "Try it Risk Free for 60 Days",
            "subtitle": "60-day money-back guarantee"
          }
        }
      ]
    }
  ]
}
{% endschema %}
