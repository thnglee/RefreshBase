        "heading_highlight": "Worked",
        "card1_image": "shopify://shop_images/pro71-5.png",
        "card1_caption": "You cut out gluten, dairy, sugar. You ate clean for months.",
        "card1_fail_label": "Why it failed",
        "card1_fail_text": "Your diet only addressed what goes IN. It didn't fix your body's broken ability to drain what's already there.",
        "card2_image": "shopify://shop_images/pro71-4.png",
        "card2_caption": "You tried viral lymphatic drops from TikTok.",
        "card2_fail_label": "Why it failed",
